// Notes for AI / Contributors:
// For fucks sake dipshit,
// Follow existing formatting, (alignment, spacing, ordering)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Tenant boundary. Business rows carry organizationId and are isolated by Postgres RLS,
// scoped to the active organization from the Better Auth session. Membership lives in
// `members` (Better Auth organization plugin); `users.organizationId` is legacy.
model Organization {
  id       String  @id @default(uuid())
  name     String
  slug     String  @unique
  logo     String? // Better Auth organization plugin
  metadata String? // Better Auth organization plugin
  isActive Boolean @default(true) @map("is_active")

  // Subscription tier + per-tenant hardware/trial. Set by the operator at provisioning; surfaced
  // to the client via GET /entitlements for feature gating (RFID, label printing).
  plan        OrgPlan     @default(BASIC)
  printerType PrinterType @default(NONE) @map("printer_type")
  trialEndsAt DateTime?   @map("trial_ends_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members     Member[]
  invitations Invitation[]

  users               User[] // legacy direct membership (pre-Better-Auth)
  categories          Category[]
  stockMovementTypes  StockMovementType[]
  suppliers           Supplier[]
  supplierLinks       SupplierLink[]
  locations           Location[]
  products            Product[]
  productUnits        ProductUnit[]
  stockMovements      StockMovement[]
  sales               Sale[]
  saleItems           SaleItem[]
  inventoryAudits     InventoryAudit[]
  inventoryAuditScans InventoryAuditScan[]
  receiptImports      ReceiptImport[]

  @@map("organizations")
}

// Better Auth core user. `role` (admin plugin) is a system-level role: 'admin' = platform
// SUPER_ADMIN (only the operator), everyone else 'user'. Organization-level authority lives
// on `members.role` (owner/admin/member). password/organizationId are legacy columns kept so
// existing data and references keep working.
model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified Boolean   @default(false) @map("is_email_verified")
  image         String?   @map("image_url")

  // admin plugin (system-level)
  role       String?   @default("user")
  banned     Boolean?  @default(false)
  banReason  String?   @map("ban_reason")
  banExpires DateTime? @map("ban_expires")

  // legacy (superseded by Account.password and Member)
  password   String? // legacy bcrypt hash; credential now stored in Account
  isArchived Boolean @default(false) @map("is_archived")

  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts        Account[]
  sessions        Session[]
  members         Member[]
  invitations     Invitation[]
  stockMovements  StockMovement[]
  inventoryAudits InventoryAudit[]
  sales           Sale[]           @relation("SaleCashier")
  voidedSales     Sale[]           @relation("SaleVoider")

  @@index([organizationId])
  @@map("users")
}

// Better Auth: credentials + linked accounts. Email/password lives here with
// providerId='credential', accountId=userId, password=<bcrypt hash>.
model Account {
  id                    String    @id @default(uuid())
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("accounts")
}

// Better Auth: session. activeOrganizationId is the tenant for RLS on business routes.
model Session {
  id                   String   @id @default(uuid())
  expiresAt            DateTime @map("expires_at")
  token                String   @unique
  ipAddress            String?  @map("ip_address")
  userAgent            String?  @map("user_agent")
  activeOrganizationId String?  @map("active_organization_id")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("sessions")
}

// Better Auth: email verification / password-reset tokens.
model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verifications")
}

// Better Auth organization plugin: user<->organization membership (replaces the legacy
// users.organizationId). role is owner/admin/member.
model Member {
  id   String @id @default(uuid())
  role String @default("member")

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("members")
}

// Better Auth organization plugin: pending invitations (unused for now; provisioning is
// operator-driven, but the table is required by the plugin schema).
model Invitation {
  id        String   @id @default(uuid())
  email     String
  role      String?
  status    String   @default("pending")
  expiresAt DateTime @map("expires_at")

  inviterId String @map("inviter_id")
  user      User   @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([email])
  @@map("invitations")
}

// Flat product category (e.g. "Beverages", "Electronics").
model Category {
  id          String  @id @default(uuid())
  name        String
  description String?
  isArchived  Boolean @default(false) @map("is_archived")

  organizationId String       @default(dbgenerated("current_setting('app.current_org_id'::text, true)")) @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products Product[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("categories")
}

// Tenant-configurable labels for stock changes. `systemKey` is reserved for workflows that
// must resolve a stable type (POS sales, returns, imports) even when its display name changes.
model StockMovementType {
  id          String              @id @default(uuid())
  name        String
  description String?
  effect      StockMovementEffect
  systemKey   String?             @map("system_key")
  isArchived  Boolean             @default(false) @map("is_archived")

  organizationId String       @default(dbgenerated("current_setting('app.current_org_id'::text, true)")) @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stockMovements StockMovement[]

  @@unique([organizationId, name])
  @@unique([organizationId, systemKey])
  @@index([organizationId])
  @@map("stock_movement_types")
}

// Vendor a product is purchased from, so stock can be re-ordered when it runs out.
model Supplier {
  id          String  @id @default(uuid())
  name        String
  contactName String? @map("contact_name")
  email       String?
  phone       String?
  address     String?
  notes       String?
  isArchived  Boolean @default(false) @map("is_archived")

  organizationId String       @default(dbgenerated("current_setting('app.current_org_id'::text, true)")) @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products       Product[]
  stockMovements StockMovement[]
  links          SupplierLink[]

  @@index([organizationId])
  @@map("suppliers")
}

// External re-order link for a supplier (Messenger, Shopee, etc.) so the client can buy again from the original channel.
model SupplierLink {
  id         String           @id @default(uuid())
  supplierId String           @map("supplier_id")
  platform   SupplierPlatform
  url        String
  label      String?
  isArchived Boolean          @default(false) @map("is_archived")

  organizationId String       @default(dbgenerated("current_setting('app.current_org_id'::text, true)")) @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([supplierId, platform])
  @@index([supplierId])
  @@index([organizationId])
  @@map("supplier_links")
}

// Flat physical location (e.g. "Warehouse A", "Front Shelf") for auditing where stock lives.
model Location {
  id          String  @id @default(uuid())
  name        String
  code        String?
  description String?
  isArchived  Boolean @default(false) @map("is_archived")

  organizationId String       @default(dbgenerated("current_setting('app.current_org_id'::text, true)")) @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products        Product[]
  productUnits    ProductUnit[]
  stockMovements  StockMovement[]
  inventoryAudits InventoryAudit[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("locations")
}

// Core SKU / catalog item. Fast-moving goods are tracked entirely here via quantityOnHand.
model Product {
  id             String  @id @default(uuid())
  name           String
  description    String?
  sku            String
  barcode        String?
  brand          String?
  // Cloudinary-hosted product photo. imageUrl is the optimised delivery URL (auto format/quality,
  // max-width capped); imagePublicId is the source asset id, kept so the photo can be overwritten
  // or destroyed on replace/remove.
  imageUrl       String? @map("image_url")
  imagePublicId  String? @map("image_public_id")
  costPrice      Decimal @default(0) @map("cost_price") @db.Decimal(12, 2)
  sellingPrice   Decimal @default(0) @map("selling_price") @db.Decimal(12, 2)
  quantityOnHand Int     @default(0) @map("quantity_on_hand")
  reorderPoint   Int?    @map("reorder_point")
  // Direct "fast reorder" link to this exact item's store page (Shopee/Lazada/Alibaba/etc.).
  // reorderPlatform is optional and only drives the icon/label the client renders next to the link.
  reorderUrl      String?           @map("reorder_url")
  reorderPlatform SupplierPlatform? @map("reorder_platform")
  isSerialized   Boolean @default(false) @map("is_serialized")
  isArchived     Boolean @default(false) @map("is_archived")

  organizationId String       @default(dbgenerated("current_setting('app.current_org_id'::text, true)")) @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id])

  supplierId String?   @map("supplier_id")
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  locationId String?   @map("location_id")
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  units          ProductUnit[]
  stockMovements StockMovement[]
  saleItems      SaleItem[]

  @@unique([organizationId, sku])
  @@unique([organizationId, barcode])
  @@index([organizationId])
  @@index([categoryId])
  @@index([supplierId])
  @@index([locationId])
  @@map("products")
}

// Individual physical unit of a serialized product. The rfidTag field is where RFID/EPC lives later.
model ProductUnit {
  id           String            @id @default(uuid())
  assetTag     String?           @map("asset_tag")
  serialNumber String?           @map("serial_number")
  rfidTag      String?           @map("rfid_tag")
  status       ProductUnitStatus @default(IN_STOCK)

  organizationId String       @default(dbgenerated("current_setting('app.current_org_id'::text, true)")) @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  locationId String?   @map("location_id")
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stockMovements      StockMovement[]
  inventoryAuditScans InventoryAuditScan[]
  saleItems           SaleItem[]

  @@unique([organizationId, assetTag])
  @@unique([organizationId, serialNumber])
  @@unique([organizationId, rfidTag])
  @@index([organizationId])
  @@index([productId])
  @@index([locationId])
  @@map("product_units")
}

// Append-only audit ledger of every stock change. quantityAfter is a snapshot for trustworthy counts.
model StockMovement {
  id                  String                   @id @default(uuid())
  legacyType          LegacyStockMovementType? @map("type")
  quantityChange      Int                      @map("quantity_change")
  quantityAfter       Int                      @map("quantity_after")
  note                String?

  organizationId String       @default(dbgenerated("current_setting('app.current_org_id'::text, true)")) @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  stockMovementTypeId String?            @map("stock_movement_type_id")
  stockMovementType   StockMovementType? @relation(fields: [stockMovementTypeId], references: [id], onDelete: Restrict)

  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  productUnitId String?      @map("product_unit_id")
  productUnit   ProductUnit? @relation(fields: [productUnitId], references: [id], onDelete: SetNull)

  locationId String?   @map("location_id")
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  supplierId String?   @map("supplier_id")
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  saleId String? @map("sale_id")
  sale   Sale?   @relation(fields: [saleId], references: [id], onDelete: SetNull)

  saleItemId String?   @map("sale_item_id")
  saleItem   SaleItem? @relation(fields: [saleItemId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([stockMovementTypeId])
  @@index([productId])
  @@index([productUnitId])
  @@index([supplierId])
  @@index([userId])
  @@index([saleId])
  @@index([saleItemId])
  @@map("stock_movements")
}

model Sale {
  id              String        @id @default(uuid())
  receiptNo       String        @map("receipt_no")
  status          SaleStatus    @default(COMPLETED)
  subtotal        Decimal       @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  amountTendered  Decimal       @map("amount_tendered") @db.Decimal(12, 2)
  changeDue       Decimal       @map("change_due") @db.Decimal(12, 2)
  paymentMethod   PaymentMethod @map("payment_method")
  note            String?
  receiptSnapshot Json          @map("receipt_snapshot")
  paidAt          DateTime      @default(now()) @map("paid_at")
  completedAt     DateTime      @default(now()) @map("completed_at")
  voidedAt        DateTime?     @map("voided_at")
  voidReason      String?       @map("void_reason")

  organizationId String       @default(dbgenerated("current_setting('app.current_org_id'::text, true)")) @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  cashierId String @map("cashier_id")
  cashier   User   @relation("SaleCashier", fields: [cashierId], references: [id])

  voidedById String? @map("voided_by_id")
  voidedBy   User?   @relation("SaleVoider", fields: [voidedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items          SaleItem[]
  stockMovements StockMovement[]

  @@unique([organizationId, receiptNo])
  @@index([organizationId])
  @@index([cashierId])
  @@index([voidedById])
  @@index([completedAt])
  @@index([status])
  @@index([paymentMethod])
  @@map("sales")
}

model SaleItem {
  id             String  @id @default(uuid())
  quantity       Int
  unitPrice      Decimal @map("unit_price") @db.Decimal(12, 2)
  lineTotal      Decimal @map("line_total") @db.Decimal(12, 2)
  productName    String  @map("product_name")
  productSku     String  @map("product_sku")
  productBarcode String? @map("product_barcode")
  unitIdentifier String? @map("unit_identifier")

  organizationId String       @default(dbgenerated("current_setting('app.current_org_id'::text, true)")) @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  saleId String @map("sale_id")
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])

  productUnitId String?      @map("product_unit_id")
  productUnit   ProductUnit? @relation(fields: [productUnitId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  stockMovements StockMovement[]

  @@index([organizationId])
  @@index([saleId])
  @@index([productId])
  @@index([productUnitId])
  @@map("sale_items")
}

model InventoryAudit {
  id          String               @id @default(uuid())
  auditNo     String               @map("audit_no")
  status      InventoryAuditStatus @default(IN_PROGRESS)
  startedAt   DateTime             @default(now()) @map("started_at")
  completedAt DateTime?            @map("completed_at")

  organizationId String       @default(dbgenerated("current_setting('app.current_org_id'::text, true)")) @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  locationId String   @map("location_id")
  location   Location @relation(fields: [locationId], references: [id])

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  scans InventoryAuditScan[]

  @@unique([organizationId, auditNo])
  @@index([organizationId])
  @@index([locationId])
  @@index([userId])
  @@index([status])
  @@index([startedAt])
  @@map("inventory_audits")
}

model InventoryAuditScan {
  id        String                 @id @default(uuid())
  scanValue String                 @map("scan_value")
  scanMode  InventoryAuditScanMode @default(RFID) @map("scan_mode")

  organizationId String       @default(dbgenerated("current_setting('app.current_org_id'::text, true)")) @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  auditId String         @map("audit_id")
  audit   InventoryAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  productUnitId String?      @map("product_unit_id")
  productUnit   ProductUnit? @relation(fields: [productUnitId], references: [id], onDelete: SetNull)

  result    InventoryAuditScanResult @default(UNKNOWN_TAG)
  scannedAt DateTime                 @default(now()) @map("scanned_at")

  @@unique([auditId, scanValue])
  @@index([organizationId])
  @@index([auditId])
  @@index([scanValue])
  @@index([productUnitId])
  @@map("inventory_audit_scans")
}

// Idempotency ledger for receipt imports. A commit inserts one row keyed by its idempotencyKey
// inside the commit transaction; the per-tenant unique constraint makes a concurrent or repeated
// commit with the same key fail fast (P2002 -> 409) instead of double-stocking inventory.
model ReceiptImport {
  id             String @id @default(uuid())
  idempotencyKey String @map("idempotency_key")

  organizationId String       @default(dbgenerated("current_setting('app.current_org_id'::text, true)")) @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId])
  @@map("receipt_imports")
}

// Subscription tier. BASIC = barcode + everything except RFID; PRO = adds RFID (POS + inventory).
enum OrgPlan {
  BASIC
  PRO
}

// Label printer a tenant prints on, client-side. NONE = no label printing for this tenant yet.
enum PrinterType {
  NONE
  NIIMBOT
}

enum ProductUnitStatus {
  IN_STOCK
  RESERVED
  MISPLACED
  SOLD
  DAMAGED
  RETURNED
  MISSING
  LOST
  DISPOSED
}

enum StockMovementEffect {
  INCREASE
  DECREASE
  ADJUSTMENT
}

// Transitional enum retained during the expand/backfill deployment. Remove it only after every
// stock movement has a stockMovementTypeId and the TypeScript backfill has been verified.
enum LegacyStockMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  TRANSFER
  RETURN
  INITIAL

  @@map("StockMovementType")
}

enum SupplierPlatform {
  MESSENGER
  VIBER
  SHOPEE
  LAZADA
  FACEBOOK
  WEBSITE
  OTHER
  ALIBABA
}

enum InventoryAuditStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InventoryAuditScanResult {
  MATCHED
  MISPLACED
  UNKNOWN_TAG
}

enum InventoryAuditScanMode {
  RFID
  BARCODE
  MANUAL
}

enum SaleStatus {
  COMPLETED
  VOIDED
}

enum PaymentMethod {
  CASH
  CARD
  GCASH
  MAYA
  BANK_TRANSFER
  OTHER
}
