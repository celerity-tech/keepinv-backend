{
  "info": {
    "name": "Asset-Wise — Initial Products (No Stock)",
    "description": "Seeds the motorshop control-cable catalog from the handwritten inventory (page 15).\n\nRun order:\n1. '0. Login' — captures {{accessToken}}.\n2. Folder '1. Categories' — creates the 3 cable categories and captures their IDs into variables.\n3. Folders '2. Products …' — creates 22 Product records with NO stock (quantityOnHand defaults to 0), null location, null supplier.\n\nThese are Product records (catalog SKUs), NOT ProductUnit records. Edit {{baseUrl}}, {{email}}, {{password}} before running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "email", "value": "admin@example.com" },
    { "key": "password", "value": "changeme" },
    { "key": "accessToken", "value": "" },
    { "key": "clutchCategoryId", "value": "" },
    { "key": "brakeCategoryId", "value": "" },
    { "key": "speedometerCategoryId", "value": "" }
  ],
  "item": [
    {
      "name": "0. Login (run first)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const token = pm.response.json().data.accessToken;",
              "pm.collectionVariables.set('accessToken', token);",
              "pm.test('got token', () => pm.expect(token).to.be.a('string').and.not.empty);"
            ]
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
      }
    },
    {
      "name": "1. Categories",
      "item": [
        {
          "name": "Create Clutch Cable category",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.collectionVariables.set('clutchCategoryId', pm.response.json().data.id);"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Clutch Cable\",\n  \"description\": \"Motorcycle clutch control cables\"\n}" },
            "url": { "raw": "{{baseUrl}}/categories", "host": ["{{baseUrl}}"], "path": ["categories"] }
          }
        },
        {
          "name": "Create Brake Cable category",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.collectionVariables.set('brakeCategoryId', pm.response.json().data.id);"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Brake Cable\",\n  \"description\": \"Motorcycle brake control cables\"\n}" },
            "url": { "raw": "{{baseUrl}}/categories", "host": ["{{baseUrl}}"], "path": ["categories"] }
          }
        },
        {
          "name": "Create Speedometer Cable category",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.collectionVariables.set('speedometerCategoryId', pm.response.json().data.id);"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Speedometer Cable\",\n  \"description\": \"Motorcycle speedometer drive cables\"\n}" },
            "url": { "raw": "{{baseUrl}}/categories", "host": ["{{baseUrl}}"], "path": ["categories"] }
          }
        }
      ]
    },
