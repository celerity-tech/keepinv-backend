# Caddy reverse proxy with automatic Let's Encrypt TLS.
# Replace the domain + email. The domain's A record must point at this VPS's public IP,
# and ports 80 + 443 must be open, BEFORE first start (Caddy provisions the cert on boot).
{
	email admin@keepinv.com
}

api.keepinv.com {
	encode gzip
	reverse_proxy api:8000
}
