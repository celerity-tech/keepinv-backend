# --------------------------------------------
# REQUIRED: BASIC APP SETTINGS
# --------------------------------------------
NODE_ENV=production
PORT=8000

# Public origin of this API (no trailing slash). Used by Better Auth as its baseURL.
APP_URL=https://api.keepinv.com

# --------------------------------------------
# REQUIRED: DATABASE SETTINGS
# --------------------------------------------
# Runtime role. In production set this to the dedicated NON-superuser app_user role
# (see prisma/rls-setup.sql) so Row-Level Security tenant isolation is enforced.
# DATABASE_URL=postgresql://app_user:CHANGE_ME_STRONG_PASSWORD@localhost:5432/keepinv?schema=public

# Owner/superuser role, used ONLY by `prisma migrate deploy` to run DDL + enable RLS.
# Optional locally (falls back to DATABASE_URL); on Railway set it to the postgres owner URL.
DATABASE_URL=postgresql://postgres:123@localhost:5432/keepinv?schema=public

# Set to 'true' once DATABASE_URL points at the non-superuser app_user role. The app then
# refuses to boot if its role would bypass RLS. Keep 'false' during the initial rollout.
ENFORCE_RLS=false

# --------------------------------------------
# REQUIRED: AUTH SETTINGS
# --------------------------------------------
# Better Auth signing secret. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-32-plus-character-secret

# --------------------------------------------
# OPTIONAL: SECURITY HEADER SETTINGS
# --------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:4200

# --------------------------------------------
# OPTIONAL: PRODUCT IMAGE HOSTING (Cloudinary)
# --------------------------------------------
# Required for product photo upload. Get these from the Cloudinary dashboard (Settings > API Keys).
# The key MUST have upload ("create") permission — a read-only key returns 403. Leave blank to
# disable uploads (the endpoint returns 503; the rest of the app is unaffected).
# NEVER commit real values here — put them only in the (gitignored) .env.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret